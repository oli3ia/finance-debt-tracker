# Copy this file to `.env.local` and fill in the two values from your Supabase
# project (Supabase dashboard → Project Settings → API). `.env.local` is gitignored.
#
# The anon/publishable key is public by design — it's safe in the browser.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
